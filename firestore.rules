rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: check admin role with safe fallback
    function isAdmin() {
      let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid));
      return userDoc.exists && userDoc.data.role == 'admin';
    }

    // Helper: validate that required string fields exist and are non-empty
    function hasRequiredStrings(fields) {
      return fields.hasAll(request.resource.data.keys())
        && request.resource.data.keys().hasAll(fields);
    }

    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /users/{userId}/foods/{foodId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create, update: if request.auth != null && request.auth.uid == userId
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.carbsPer100g is number;
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    match /users/{userId}/history/{mealId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create, update: if request.auth != null && request.auth.uid == userId
        && request.resource.data.mealType is string
        && request.resource.data.totalCarbs is number
        && request.resource.data.totalRations is number
        && request.resource.data.items is list;
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    match /users/{userId}/settings/{docId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId
        && request.resource.data.ratioBase is number
        && request.resource.data.ratioBase > 0
        && request.resource.data.factorCorreccion is number
        && request.resource.data.factorCorreccion > 0
        && request.resource.data.glucosaObjetivo is number
        && request.resource.data.glucosaObjetivo > 0;
    }

    match /global_foods/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && isAdmin();
    }

    match /food_requests/{docId} {
      allow create: if request.auth != null
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.carbsPer100g is number
        && request.resource.data.userId == request.auth.uid;
      allow update, delete, read: if request.auth != null && isAdmin();
    }
  }
}